{
  "name": "AppSettings",
  "type": "object",
  "properties": {
    "setting_key": {
      "type": "string",
      "description": "Unique key identifier for this setting"
    },
    "setting_value": {
      "type": "string",
      "description": "Value of the setting"
    },
    "description": {
      "type": "string"
    }
  },
  "required": [
    "setting_key",
    "setting_value"
  ]
}
# ===========================================
# HERU.gg Environment Variables
# ===========================================
# Copy this file to .env (frontend) AND backend/.env (backend)
# Then fill in the values below.

# -------------------------------------------
# Supabase (required)
# -------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend only — do NOT put this in the frontend .env
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -------------------------------------------
# Frontend API URL
# -------------------------------------------
# On VPS: leave empty or set to /api (Nginx proxies to backend)
# For local dev: set to http://localhost:3001/api
VITE_API_URL=/api

# -------------------------------------------
# Backend
# -------------------------------------------
PORT=3001
NODE_ENV=production
# CORS_ORIGIN: set to your domain or VPS IP
# On VPS with Nginx proxy, same-origin so CORS isn't strictly needed
CORS_ORIGIN=http://YOUR_VPS_IP

# -------------------------------------------
# Payments — Paymob (MENA gateway)
# -------------------------------------------
PAYMOB_API_KEY=your-paymob-key
PAYMOB_INTEGRATION_ID=your-integration-id
PAYMOB_IFRAME_ID=your-iframe-id
PAYMOB_HMAC_SECRET=your-hmac-secret
PAYMOB_ENABLED=false

# -------------------------------------------
# Email — Resend
# -------------------------------------------
RESEND_API_KEY=your-resend-key
FROM_EMAIL=noreply@heru.gg

# -------------------------------------------
# Platform
# -------------------------------------------
PLATFORM_FEE_PERCENT=15

# -------------------------------------------
# HERU CONNECT — Discord OAuth
# -------------------------------------------
DISCORD_CLIENT_ID=1494378715709313064
DISCORD_CLIENT_SECRET=your-discord-client-secret
# Redirect URI must match what is set in Discord Developer Portal → OAuth2 → Redirects
DISCORD_REDIRECT_URI=http://localhost:3001/api/connect/discord/callback

# -------------------------------------------
# HERU CONNECT — Riot Games API
# -------------------------------------------
# Dev key expires daily — renew at developer.riotgames.com
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RIOT_DEFAULT_REGION=euw1

# -------------------------------------------
# HERU BOT — Discord Bot
# -------------------------------------------
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_APPLICATION_ID=1494378715709313064
DISCORD_PUBLIC_KEY=c45d95e3caf99616bc2a6a807fac9dc93951a82fcd483e02c086d086a9352a2c
# Generate: openssl rand -hex 32
HERU_BOT_SECRET=your-64-char-random-secret
# URL the bot calls to reach the backend
HERU_API_URL=http://localhost:3001
# URL the bot sends to gamers
HERU_FRONTEND_URL=https://heru.gg

# -------------------------------------------
# AI Agent — Anthropic Claude
# -------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key
AI_AGENT_MODEL=claude-opus-4-7
AI_AGENT_MAX_TOKENS=4096
# Max messages per user per hour
AI_AGENT_HOURLY_LIMIT=20

# -------------------------------------------
# Frontend — Discord app ID (for bot install fallback)
# -------------------------------------------
VITE_DISCORD_APPLICATION_ID=1494378715709313064
